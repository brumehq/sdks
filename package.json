{
  "name": "brume-sdks",
  "version": "0.0.0",
  "private": true,
  "description": "All Brume Realtime Gateway SDKs across languages. Source of truth is brumehq/brume; this repo is populated by CI.",
  "workspaces": [
    "sdks/typescript/*"
  ],
  "scripts": {
    "build:ts": "bun run --filter='@brume/rest' --filter='@brume/client' --filter='@brume/server' --filter='@brume/react' --filter='@brume/protocol' --filter='@brume/testing' build",
    "typecheck:ts": "bun run --filter='@brume/rest' --filter='@brume/client' --filter='@brume/server' --filter='@brume/react' --filter='@brume/protocol' --filter='@brume/testing' typecheck",
    "test:ts": "bun run --filter='@brume/rest' --filter='@brume/client' --filter='@brume/server' --filter='@brume/react' --filter='@brume/protocol' --filter='@brume/testing' test"
  },
  "engines": {
    "node": ">=20"
  }
}
